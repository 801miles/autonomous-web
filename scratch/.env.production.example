# Copy to `.env.production` and fill in. Then run:
#   powershell -ExecutionPolicy Bypass -File scripts\vercel-env-push-from-dotenv.ps1
#
# Supabase: Project Settings → Database → Connection string (URI), Transaction pooler, port 6543.

NEXT_PUBLIC_APP_URL=https://www.autonomousweb.app

# Prisma 7 + serverless: use Supabase Transaction pooler (6543) with ?pgbouncer=true&connection_limit=1
# or direct db.*.supabase.co:5432 if your host supports IPv6 to that region.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional
POST_PURCHASE_WEBHOOK_URL=
